ORY=$(free -h | awk '/Mem:/ {print $2}')\n      STORAGE=$(df -h / | awk 'NR==2 {print $2}')\n      FILESYSTEM=$(df -T / | awk 'NR==2 {print $2}')\n      HYPERVISOR=$(systemd-detect-virt || echo \"unknown\")\n\n      cat \u003e /var/www/html/index.html \u003c\u003cEOF\n      \u003c!DOCTYPE html\u003e\n      \u003chtml\u003e\n      \u003chead\u003e\n        \u003cmeta charset=\"UTF-8\"\u003e\n        \u003ctitle\u003eVM Informationen\u003c/title\u003e\n      \u003c/head\u003e\n      \u003cbody\u003e\n        \u003ch1\u003eTechnische Details der VM\u003c/h1\u003e\n        \u003cul\u003e\n          \u003cli\u003e\u003cstrong\u003eHostname:\u003c/strong\u003e $HOSTNAME\u003c/li\u003e\n          \u003cli\u003e\u003cstrong\u003ePublic IP:\u003c/strong\u003e $PUBLIC_IP\u003c/li\u003e\n          \u003cli\u003e\u003cstrong\u003eBetriebssystem:\u003c/strong\u003e $OS\u003c/li\u003e\n          \u003cli\u003e\u003cstrong\u003eKernel:\u003c/strong\u003e $KERNEL\u003c/li\u003e\n          \u003cli\u003e\u003cstrong\u003eMemory:\u003c/strong\u003e $MEMORY\u003c/li\u003e\n          \u003cli\u003e\u003cstrong\u003eStorage:\u003c/strong\u003e $STORAGE\u003c/li\u003e\n          \u003cli\u003e\u003cstrong\u003eFilesystem:\u003c/strong\u003e $FILESYSTEM\u003c/li\u003e\n          \u003cli\u003e\u003cstrong\u003eHypervisor:\u003c/strong\u003e $HYPERVISOR\u003c/li\u003e\n        \u003c/ul\u003e\n        \u003cp\u003eJSON API: \u003ca href=\"/api/\"\u003e/api/\u003c/a\u003e\u003c/p\u003e\n      \u003c/body\u003e\n      \u003c/html\u003e\n      EOF\n\n      cat \u003e /var/www/html/api/index.html \u003c\u003cEOF\n      {\n        \"hostname\": \"$HOSTNAME\",\n        \"public_ip\": \"$PUBLIC_IP\",\n        \"operating_system\": \"$OS\",\n        \"kernel\": \"$KERNEL\",\n        \"memory\": \"$MEMORY\",\n        \"storage\": \"$STORAGE\",\n        \"filesystem\": \"$FILESYSTEM\",\n        \"hypervisor\": \"$HYPERVISOR\"\n      }\n      EOF\n\nruncmd:\n  - systemctl enable nginx\n  - systemctl start nginx\n  - /usr/local/bin/create-vm-info.sh\n","zone":"de-fra-1"},"sensitive_attributes":[],"private":"eyJlMmJmYjczMC1lY2FhLTExZTYtOGY4OC0zNDM2M2JjN2M0YzAiOnsiY3JlYXRlIjozNjAwMDAwMDAwMDAwLCJkZWxldGUiOjM2MDAwMDAwMDAwMDAsInJlYWQiOjM2MDAwMDAwMDAwMDAsInVwZGF0ZSI6MzYwMDAwMDAwMDAwMH19","dependencies":["data.exoscale_template.ubuntu","exoscale_security_group.vm_security_group"]}]},{"mode":"managed","type":"exoscale_security_group","name":"vm_security_group","provider":"provider[\"registry.opentofu.org/exoscale/exoscale\"]","instances":[{"schema_version":1,"attributes":{"description":null,"external_sources":null,"id":"09fdc787-f6fd-456a-905c-526ebc333a3b","name":"vm-info-security-group-linda-2","timeouts":null},"sensitive_attributes":[]}]},{"mode":"managed","type":"exoscale_security_group_rule","name":"http","provider":"provider[\"registry.opentofu.org/exoscale/exoscale\"]","instances":[{"schema_version":0,"attributes":{"cidr":"0.0.0.0/0","description":null,"end_port":80,"icmp_code":null,"icmp_type":null,"id":"70d31de1-c31d-4732-bf2d-8bf9fd391bca","protocol":"TCP","public_security_group":null,"security_group_id":"09fdc787-f6fd-456a-905c-526ebc333a3b","start_port":80,"timeouts":null,"type":"INGRESS","user_security_group_id":null},"sensitive_attributes":[],"dependencies":["exoscale_security_group.vm_security_group"]}]},{"mode":"managed","type":"exoscale_security_group_rule","name":"ssh","provider":"provider[\"registry.opentofu.org/exoscale/exoscale\"]","instances":[{"schema_version":0,"attributes":{"cidr":"0.0.0.0/0","description":null,"end_port":22,"icmp_code":null,"icmp_type":null,"id":"de9098a5-5b20-45b4-bbbc-85972f624fba","protocol":"TCP","public_security_group":null,"security_group_id":"09fdc787-f6fd-456a-905c-526ebc333a3b","start_port":22,"timeouts":null,"type":"INGRESS","user_security_group_id":null},"sensitive_attributes":[],"dependencies":["exoscale_security_group.vm_security_group"]}]}],"check_results":null}
